# eBay Sandbox
EBAY_SANDBOX_CLIENT_ID=
EBAY_SANDBOX_CLIENT_SECRET=
EBAY_SANDBOX_DEV_ID=

# eBay Production
EBAY_PROD_CLIENT_ID=
EBAY_PROD_CLIENT_SECRET=
EBAY_PROD_DEV_ID=

# Active environment: sandbox | production
EBAY_ENV=sandbox

# OAuth callback RuName (set in eBay Developer Portal → Your Applications → OAuth → RuName)
EBAY_RU_NAME=

# User OAuth token (generated via browser flow — run `pnpm get-token`)
EBAY_USER_TOKEN=

# Anthropic
ANTHROPIC_API_KEY=

# eBay Business Policies (get from Seller Hub → Account → Business Policies)
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_MERCHANT_LOCATION_KEY=

# Shared secret for MCP endpoint authentication
# Generate with: openssl rand -hex 32
MCP_SECRET=

# Transport: http or stdio (default: http)
MCP_TRANSPORT=http

# Cloudflare R2 (for image uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# Server
PORT=3100
LOG_LEVEL=info

# Public base URL for the upload endpoint (used by get_upload_url tool)
UPLOAD_BASE_URL=https://ebay-mcp.aetnios.com
