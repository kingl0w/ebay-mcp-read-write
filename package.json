{
  "name": "ebay-mcp",
  "version": "0.1.0",
  "description": "MCP server for eBay listing management with AI-powered listing drafts",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "test": "vitest",
    "lint": "biome check",
    "start": "node dist/index.js",
    "get-token": "tsx scripts/get-token.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@aws-sdk/client-s3": "^3.1020.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
